# shunt configuration — copy to ./shunt.toml and edit.
# Every provider below has a built-in default, so you only need the keys you
# want to change. See docs/running.md §3 for the full reference.
# Env overrides: SHUNT_ prefix, __ for nesting (e.g. SHUNT_SERVER__BIND=0.0.0.0:3001).

[server]
bind = "127.0.0.1:3001"        # address shunt listens on (ANTHROPIC_BASE_URL points here)
default_provider = "anthropic" # provider for any model with no route -> pass-through to Anthropic
# sse_keepalive_seconds = 30   # (default) inject an SSE `ping` after this much upstream
                               # silence so middlebox idle timers (Cloudflare 100s -> 524)
                               # never kill a quiet stream; 0 disables (docs/running.md §5.10)

# --- Optional: inbound client tokens for a shared gateway (docs/running.md §5.9).
# When set, models routed to a credential-injecting provider (api_key /
# chatgpt_oauth / claude_oauth) and GET /v1/models require a client token;
# passthrough models stay open. Both gates accept the configured header plus
# bearer authorization and x-api-key (so Claude Code's ANTHROPIC_AUTH_TOKEN
# works as-is on a pool-only gateway). Tokens live in the env, never here:
# SHUNT_CLIENT_TOKENS="alice:<token>,bob:<token>".
# Startup fails if the env var is unset (never silently open).
# [server.auth]
# header = "x-shunt-token"           # (default) header the client sends
# tokens_env = "SHUNT_CLIENT_TOKENS" # (default) env var with name:token pairs

# --- Optional: admin web surface for browser account provisioning and pool health.
# Separate from client auth: admin credentials live in the env, never here, as
# SHUNT_ADMIN_TOKENS="ops:<token>,backup:<token>". Startup fails if this table
# is present but the env var is unset or empty (never silently open).
# [server.admin]
# header = "x-shunt-admin-token"       # (default) header for API/curl calls
# tokens_env = "SHUNT_ADMIN_TOKENS"    # (default) env var with name:token pairs
# session_ttl_secs = 3600              # (default) browser session lifetime
# pending_ttl_secs = 600               # (default) provisioning-flow lifetime

# --- Optional: quota-aware Claude pool tuning and usage reconciliation
# (docs/m8-anthropic-multi-account.md). Absent, selection uses the built-in
# 0.98 threshold and no background poller runs. Soft thresholds resolve as:
# account threshold_<X> -> account threshold -> default_threshold_<X> ->
# default_threshold -> hard_threshold. Quota tuning is inert for Codex pools;
# per-account priority/disabled still apply there.
# [server.pool]
# hard_threshold = 0.98          # (default) backstop; accounts at/above sort last
# default_threshold = 0.9        # soft default (unset: hard_threshold)
# default_threshold_5h = 0.95    # per-window overrides
# default_threshold_7d = 0.9
# default_threshold_fable = 0.85 # Fable-only 7d_oi bucket
# burn_rate_avoidance = false    # avoid projected exhaustion before reset
# usage_refresh_seconds = 300    # (disabled by default; 0 disables) poll usage
#                                    API for refreshable Claude accounts only;
#                                    values below 60 clamp to 60, fixed at boot

# --- Optional: Sentry error reporting to YOUR OWN Sentry project (docs/running.md §3.1).
# Off unless you set a DSN. Reports gateway-owned diagnostics only — fatal
# gateway startup/serve errors, panics, and error-level log events (warn/info as
# breadcrumbs, message only: log field values are stripped); request/response
# bodies, headers, and credentials are never sent. SHUNT_SENTRY__DSN=""
# disables again.
# [sentry]
# dsn = "https://<key>@<org>.ingest.sentry.io/<project>"
# environment = "home-lab"     # optional environment tag on events
# metrics = false              # (default) separate opt-in: also send usage metrics —
                               # inference request counts + latency tagged provider,
                               # model, `http.response.status_code` (aggregates only;
                               # no prompts, client names, or session ids)
# traces_sample_rate = 0.0     # (default) separate opt-in: also send performance
                               # traces — the per-request span (method, path) becomes
                               # a Sentry transaction, head-sampled at this rate in
                               # [0.0, 1.0]; 0.0 sends no spans at all
# include_session_id = false   # (default) withhold the client session id from
                               # spans sent to Sentry (mirrors [otel])

# --- Optional: OpenTelemetry (OTLP) export to YOUR OWN collector/backend
# (docs/running.md §3.1). Off unless you set an endpoint. Independent of
# [sentry] — both can run together. Exports up to three signals over OTLP/HTTP
# (protobuf): request spans (traces), the shunt.requests/shunt.latency series
# (metrics), and shunt's log events (logs). Metrics + traces are low-cardinality
# and body-free (the span session id only when include_session_id = true); the
# logs signal exports shunt's diagnostic events as written, so it can carry
# request-derived fields (upstream error bodies, client ids) — set logs = false
# for body-free export. SHUNT_OTEL__ENDPOINT="" disables again. endpoint and
# service_name come from this config (over OTEL_EXPORTER_OTLP_ENDPOINT /
# OTEL_SERVICE_NAME); OTEL_EXPORTER_OTLP_HEADERS and OTEL_RESOURCE_ATTRIBUTES are
# merged in. Editing [otel] then hot-reloading needs a restart to take effect.
# [otel]
# endpoint = "http://localhost:4318"  # OTLP/HTTP base URL; /v1/{traces,metrics,logs} appended
# service_name = "shunt"       # (default) service.name resource attribute
# environment = "prod"         # optional deployment.environment.name
# sample_ratio = 1.0           # (default) head-based trace sampling in [0.0, 1.0]
# traces = true                # (default) export request spans
# metrics = true               # (default) export usage metrics
# logs = true                  # (default) export log events (stderr logs unaffected)
# include_session_id = false   # (default) withhold the client session id from spans
# [otel.headers]               # optional per-request headers, e.g. a hosted-collector token
# authorization = "Bearer <token>"

# --- Providers: each is a `[providers.<name>]` table. Add a new upstream by
# adding a table — no code change. Every provider has these keys:
#   kind           = "anthropic" | "responses" | "cursor" (which upstream protocol)
#   base_url       = "https://…"                  (Claude Code appends /v1/messages)
#   auth           = "passthrough" | "api_key" | "chatgpt_oauth" | "cursor_oauth"
#   api_key_env    = "ENV_NAME"                   (when auth = "api_key")
#   api_key_header = "bearer" | "x_api_key"       (default bearer)
#   effort         = "low|medium|high|xhigh|max"  (optional; responses providers)
#   [providers.<name>.retry]                      (optional; bounded transient retry, see below)
# The three below are built-in defaults; you only need the keys you change.

# Anthropic itself: forward Claude Code's own credential unchanged.
[providers.anthropic]
kind = "anthropic"
base_url = "https://api.anthropic.com"
# auth = "passthrough"         # (default)

# OpenAI API (real OpenAI, authenticated with an API key).
[providers.openai]
kind = "responses"
base_url = "https://api.openai.com/v1"
auth = "api_key"
api_key_env = "OPENAI_API_KEY" # env var shunt reads the key from
# effort = "high"              # optional default reasoning effort (low|medium|high|xhigh|max)
# Bounded retry/backoff for transient upstream failures (issue #48). On by
# default with these conservative values; retries only 429/502/503/504 and
# connection errors (never other 4xx), stays pre-stream, honors Retry-After,
# and is always off for count_tokens. Set max_retries = 0 to disable.
# [providers.openai.retry]
# max_retries = 2              # extra attempts after the first (0 disables; max 10)
# initial_backoff_ms = 500     # backoff ceiling before the first retry (jitter fills [0, this])
# max_backoff_ms = 8000        # cap on any backoff and on an honored Retry-After
# multiplier = 2.0             # exponential growth factor per attempt (>= 1.0)

# ChatGPT / Codex subscription (reuses ~/.codex/auth.json — run `codex login`).
[providers.codex]
kind = "responses"
base_url = "https://chatgpt.com/backend-api"
auth = "chatgpt_oauth"         # reads + auto-refreshes ~/.codex/auth.json
# effort = "high"              # low|medium|high|xhigh; gpt-5.6 slugs also accept "max"
# count_tokens = "tiktoken"    # default: local o200k_base count for count_tokens.
                               # "estimate" opts out (404 -> client estimates).
# websocket = true             # EXPERIMENTAL (issue #32): reach the Codex backend
                               # over the Responses WebSocket v2 transport instead
                               # of HTTP. Pools a connection per conversation and
                               # reuses previous_response_id to upload only the new
                               # input. Only honored for this ChatGPT/Codex backend;
                               # falls back to HTTP if the socket can't be opened.

# --- Optional: pool several ChatGPT accounts behind [providers.codex] instead of
# one ~/.codex/auth.json. Session-sticky selection + cooldown-based reactive
# failover only (no per-account quota headers -> no proactive rotation).
# See docs/m10-codex-multi-account.md.
# `shunt login codex --name main` imports an existing `codex login` into the
# store; SHUNT_CODEX_ACCOUNTS_DIR overrides the store directory.
# [[providers.codex.accounts]]
# name = "main"                 # store-managed: resolves ~/.shunt/accounts/codex/main.json
#
# [[providers.codex.accounts]]
# name = "backup"
# token_env = "CODEX_BACKUP_ACCESS_TOKEN"  # raw ChatGPT access token, used verbatim (not refreshed)

# Cursor subscription via ConnectRPC. Run `shunt login cursor`; credentials are
# stored in ~/.shunt/cursor-auth.json and refreshed automatically.
# [providers.cursor]
# kind = "cursor"
# base_url = "https://api2.cursor.sh"
# auth = "cursor_oauth"
# count_tokens = "tiktoken"

# xAI Grok (EXPERIMENTAL). Two built-in providers cover the two ways in — you
# only need to add [[routes]] (grok-build-0.1, grok-4.5, grok-4.3). Pick one:
#   • `xai`  — API key: the developer API (api.x.ai), billed per token.
#              export XAI_API_KEY, then route models to provider = "xai".
#   • `grok` — SuperGrok / X Premium+ subscription: the Grok CLI chat proxy
#              (cli-chat-proxy.grok.com), no API billing. Run `shunt login xai`
#              once, then route models to provider = "grok". The developer API
#              rejects a subscription bearer (402/403), so the OAuth path targets
#              the CLI surface and sends the Grok-CLI identity headers.
# xAI may gate OAuth API access by tier (SuperGrok Heavy); if `grok` returns 403,
# use the `xai` API-key path instead. See docs/m6-xai-provider.md.
# Override a built-in only to change a default, e.g. a route-level effort:
# [providers.grok]
# effort = "high"              # opt-in: several grok models 400 on reasoning.effort, so it is
                               # only sent when you configure an effort here or on a route.

# --- Anthropic-compatible gateways: all `kind = "anthropic"` + an injected key.
# Uncomment one, set its api_key_env, then add a matching [[routes]] below.
# (Each provider's own model IDs are shown in a comment.)

# [providers.kimi]              # kimi-k2.7-code
# kind = "anthropic"
# base_url = "https://api.moonshot.ai/anthropic"
# auth = "api_key"
# api_key_env = "KIMI_API_KEY"

# [providers.deepseek]          # deepseek-v4-pro, deepseek-v4-flash
# kind = "anthropic"
# base_url = "https://api.deepseek.com/anthropic"
# auth = "api_key"
# api_key_env = "DEEPSEEK_API_KEY"

# [providers.zai]               # glm-5.2, glm-4.7
# kind = "anthropic"
# base_url = "https://api.z.ai/api/anthropic"
# auth = "api_key"
# api_key_env = "ZAI_API_KEY"

# [providers.minimax]           # see https://platform.minimax.io/docs/token-plan/claude-code
# kind = "anthropic"
# base_url = "https://api.minimax.io/anthropic"
# auth = "api_key"
# api_key_env = "MINIMAX_API_KEY"

# [providers.mimo]              # mimo-v2.5-pro; see https://mimo.mi.com/docs/en-US/tokenplan/integration/claudecode
# kind = "anthropic"
# base_url = "https://api.xiaomimimo.com/anthropic"       # pay-as-you-go; Token Plan: https://token-plan-cn.xiaomimimo.com/anthropic
# auth = "api_key"
# api_key_env = "MIMO_API_KEY"

# [providers.openrouter]        # e.g. anthropic/claude-opus-4.8, ~anthropic/claude-sonnet-latest
# kind = "anthropic"
# base_url = "https://openrouter.ai/api"
# auth = "api_key"
# api_key_env = "OPENROUTER_API_KEY"

# [providers.vercel]            # e.g. anthropic/claude-opus-4.8 (Vercel AI Gateway)
# kind = "anthropic"
# base_url = "https://ai-gateway.vercel.sh"
# auth = "api_key"
# api_key_env = "AI_GATEWAY_API_KEY"
# api_key_header = "x_api_key"  # Vercel accepts bearer too; x-api-key is native

# --- Routing: a request's `model` id picks the provider ---
# Precedence: exact [[routes]] match -> [[route_prefixes]] -> server.default_provider.

# Example A — route to the OpenAI API. `upstream_model`/`effort` are optional overrides.
[[routes]]
model = "gpt-5.2"
provider = "openai"
# upstream_model = "gpt-5.2"
# effort = "high"

# Example B — route to your ChatGPT subscription via Codex.
# The ChatGPT-account backend REJECTS gpt-*-codex slugs; it only accepts the
# account's live-entitled slugs. The catalog of valid Codex slugs (and the
# reasoning levels each accepts) is openai/codex's models.json:
#   https://github.com/openai/codex/blob/main/codex-rs/models-manager/models.json
# The latest are gpt-5.6-sol / gpt-5.6-terra / gpt-5.6-luna; older accounts may
# only be entitled to gpt-5.5 / gpt-5.4 / gpt-5.2. See docs/m2-chatgpt-oauth.md §0.
# [[routes]]
# model = "gpt-5.6-sol"
# provider = "codex"

# Example C — route to Cursor. Prefixes select agent mode and the suffix is the
# Cursor model id (for example cursor:gpt-5.5 or cursor-plan:gpt-5.5).
# [[routes]]
# model = "cursor:gpt-5.5"
# provider = "cursor"

# Example D — route to an Anthropic-compatible gateway (see the providers above).
# The model id is whatever that gateway expects; select it in Claude Code with
# ANTHROPIC_MODEL / the /model picker. shunt injects the provider's api_key_env.
# [[routes]]
# model = "kimi-k2.7-code"
# provider = "kimi"

# Catch-all: send every gpt-* id to a provider.
[[route_prefixes]]
prefix = "gpt-"
provider = "openai"

# Model discovery (GET /v1/models) for the /model picker.
# Claude Code IGNORES ids that don't begin with claude/anthropic, so gpt-* ids
# never appear here — select those with ANTHROPIC_CUSTOM_MODEL_OPTION instead.
# To surface a mapped model via discovery, expose a Claude-named ALIAS whose
# [[routes]] entry rewrites it to the real upstream slug. It then shows in /model
# labeled "From gateway". Requires CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1.
# [[models]]
# id = "claude-gpt-5.6-sol-via-codex"    # must begin with claude/anthropic
# display_name = "GPT-5.6-Sol (via Codex)"
#
# [[routes]]
# model = "claude-gpt-5.6-sol-via-codex" # the alias Claude Code sends
# provider = "codex"
# upstream_model = "gpt-5.6-sol"         # real slug forwarded upstream (see models.json)
